{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "cassandra-portal",
  "main": "src/index.ts",
  "compatibility_date": "2025-03-10",
  "compatibility_flags": ["nodejs_compat"],
  "kv_namespaces": [
    {
      "binding": "MCP_KEYS",
      "id": "<your-mcp-keys-kv-namespace-id>"
    }
  ],
  "routes": [
    {
      "pattern": "<subdomain>.<domain>/*",
      "zone_name": "<domain>"
    }
  ],
  "observability": {
    "enabled": true
  },
  "dev": {
    "port": 8791
  }
}
